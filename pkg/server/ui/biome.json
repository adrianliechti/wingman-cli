{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "css": {
    "parser": {
      "cssModules": false,
      "tailwindDirectives": true
    }
  },
  "linter": {
    "rules": {
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "warn"
      },
      "suspicious": {
        "noArrayIndexKey": "off"
      }
    }
  }
}
